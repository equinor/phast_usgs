dist_example_phrqex11_DATA = $(phrqex11)
phrqex11 = \
     phrqex11/phast.dat \
     phrqex11/phrqex11.chem.dat \
     phrqex11/phrqex11.trans.dat


# property
#
example_propertydir = $(EXAMPLES_DIR)/property
dist_example_property_DATA = $(property)
property = \
     property/phast.dat \
     property/property.chem.dat \
     property/property.mix \
     property/property.mix.xyzt \
     property/property.solns \
     property/property.trans.dat \
     property/property.xyzt


# radial
#
example_radialdir = $(EXAMPLES_DIR)/radial
dist_example_radial_DATA = $(radial)
radial = \
     radial/phast.dat \
     radial/radial.chem.dat \
     radial/radial.head.dat \
     radial/radial.trans.dat


# river
#
example_riverdir = $(EXAMPLES_DIR)/river
dist_example_river_DATA = $(river)
river = \
     river/river.trans.dat


# shell
#
example_shelldir = $(EXAMPLES_DIR)/shell
dist_example_shell_DATA = $(shell)
shell = \
     shell/phast.dat \
     shell/shell.chem.dat \
     shell/shell.trans.dat


# simple
#
example_simpledir = $(EXAMPLES_DIR)/simple
dist_example_simple_DATA = $(simple)
simple = \
     simple/phast.dat \
     simple/simple.chem.dat \
     simple/simple.trans.dat


# unconf
#
example_unconfdir = $(EXAMPLES_DIR)/unconf
dist_example_unconf_DATA = $(unconf)
unconf = \
     unconf/unconf.trans.dat


# well
#
example_welldir = $(EXAMPLES_DIR)/well
dist_example_well_DATA = $(well)
well = \
     well/phast.dat \
	 well/well.chem.dat \
     well/well.trans.dat


# zf
#
example_zfdir = $(EXAMPLES_DIR)/zf
dist_example_zf_DATA = $(zf)
zf = \
     zf/phast.dat \
     zf/zf.chem.dat \
     zf/zf.subgrid.heads \
     zf/zf.trans.dat


# ZoneSteady
#
example_ZoneSteadydir = $(EXAMPLES_DIR)/ZoneSteady
dist_example_ZoneSteady_DATA = $(ZoneSteady)
ZoneSteady = \
     ZoneSteady/ZoneSteady.trans.dat

all: all-am

.SUFFIXES:
$(srcdir)/Makefile.in:  $(srcdir)/Makefile.am  $(am__configure_deps)
	@for dep in $?; do \
	  case '$(am__configure_deps)' in \
	    *$$dep*) \
	      ( cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh ) \
	        && { if test -f $@; then exit 0; else break; fi; }; \
	      exit 1;; \
	  esac; \
	done; \
	echo ' cd $(top_srcdir) && $(AUTOMAKE) --foreign examples/Makefile'; \
	$(am__cd) $(top_srcdir) && \
	  $(AUTOMAKE) --foreign examples/Makefile
Makefile: $(srcdir)/Makefile.in $(top_builddir)/config.status
	@case '$?' in \
	  *config.status*) \
	    cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh;; \
	  *) \
	    echo ' cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__depfiles_maybe)'; \
	    cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__depfiles_maybe);; \
	esac;

$(top_builddir)/config.status: $(top_srcdir)/configure $(CONFIG_STATUS_DEPENDENCIES)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh

$(top_srcdir)/configure:  $(am__configure_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(ACLOCAL_M4):  $(am__aclocal_m4_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(am__aclocal_m4_deps):
install-dist_example_ZoneSteadyDATA: $(dist_example_ZoneSteady_DATA)
	@$(NORMAL_INSTALL)
	@list='$(dist_example_ZoneSteady_DATA)'; test -n "$(example_ZoneSteadydir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(example_ZoneSteadydir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(example_ZoneSteadydir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(example_ZoneSteadydir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(example_ZoneSteadydir)" || exit $$?; \
	done

uninstall-dist_example_ZoneSteadyDATA:
	@$(NORMAL_UNINSTALL)
	@list='$(dist_example_ZoneSteady_DATA)'; test -n "$(example_ZoneSteadydir)" || list=; \
	files=`for p in $$list; do echo $$p; done | sed -e 's|^.*/||'`; \
	dir='$(DESTDIR)$(example_ZoneSteadydir)'; $(am__uninstall_files_from_dir)
