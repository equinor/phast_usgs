install-dist_example_ex6DATA: $(dist_example_ex6_DATA)
	@$(NORMAL_INSTALL)
	@list='$(dist_example_ex6_DATA)'; test -n "$(example_ex6dir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(example_ex6dir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(example_ex6dir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(example_ex6dir)'"; \
